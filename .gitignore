# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

dist*

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# vendored binaries (downloaded by preBuild script, never commit these)
/vendors

# NeMo ITN static lib (built from text-processing-rs in pre-build)
/native/CodictateParakeetHelper/Vendor/
# Swift Package Manager build artifacts (never commit these)
/native/CodictateParakeetHelper/.build/
/native/CodictateFormatterHelper/.build/
artifacts/

# guard against accidentally committing large binaries back into source tree
src/bun/utils/whisper/whisper-cli
src/bun/utils/whisper/ggml-base.en.bin

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
