# Build secrets — copy this file to .env and fill in your values.
# .env is gitignored; never commit it.

# Absolute path to your local codictate-releases repo clone.
# Artifacts are automatically copied here after each canary/stable build.
RELEASES_REPO_PATH=/Users/yourname/path/to/codictate-releases

# ── Code signing & notarization (requires paid Apple Developer membership) ────

# Your "Developer ID Application: Name (TEAMID)" certificate exactly as it appears in Keychain
ELECTROBUN_DEVELOPER_ID=Developer ID Application: Your Name (XXXXXXXXXX)

# Your 10-character Apple Team ID (visible at developer.apple.com → Membership)
ELECTROBUN_TEAMID=XXXXXXXXXX

# The Apple ID email you use to sign in to developer.apple.com
ELECTROBUN_APPLEID=you@example.com

# An app-specific password generated at appleid.apple.com (not your regular Apple ID password)
ELECTROBUN_APPLEIDPASS=xxxx-xxxx-xxxx-xxxx
